    <%- include('partials/head.ejs') %>
    <style>
    body{ 
        background-image: url("<%= image %>");
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        font-family: Arial, Helvetica, sans-serif;
        margin: 0;
        color: white;
    }

    .container {
      max-width: 900px;
      margin: 2rem auto;
      padding: 2rem;
      background: rgba(0, 0, 0, 0.7);
      border-radius: 12px;
      text-align: center;
    }

    h1 {
    margin-top: 0;
    font-size: 3rem;
    }

    h2 {
      margin-top: 2rem;
      color: #ffd54f;
    }

    img {
      max-width: 100%;
      border-radius: 10px;
      margin: 1rem 0;
    }

    p {
      line-height: 1.7;
      text-align: justify;
    }
    footer {
      margin-top: 2rem;
      padding: 20px;
      background: rgba(0, 0, 0, 0.8);
      color: white;
      text-align: center;
      border-top: 2px solid #ffd54f;
    }

    footer p {
      margin: 5px 0;
    }

    footer code {
      color: #ffd54f;
      background: transparent;
    }
 	  </style>
    <div class="container">
      <h1>The Solar System</h1>
      <%- include('partials/nav.ejs') %>
      <img src="/img/solar-system.jpg" />
      <h2>NASA Picture Of The Day</h2>
      <img src="<%= nasaImage %>" />
      <p><%= nasaDescription  %></p>
    </div>
    <%- include('partials/footer.ejs') %>
  </body>
</html>
